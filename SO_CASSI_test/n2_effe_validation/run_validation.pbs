#!/bin/bash
#PBS -A starting_2025_097
#PBS -l nodes=1:ppn=1
#PBS -l walltime=02:00:00
#PBS -l mem=8gb
#PBS -m be
#PBS -M joachim.scheerlinck@ugent.be
#
# N2 CAS(6,6) / cc-pVDZ / 8 singlet roots — EFFE validation.
#
# Runs three sequential pymolcas jobs in one PBS allocation:
#   A        : Multistate=all  →  reference RASSI energies
#   B_roots  : ONLY=1..8       →  per-root H_eff rows
#   B_effe   : EFFE assembled  →  RASSI energies from reconstructed H_eff
#
# Then compare_energies.py checks all 8 state energies match to 1e-7 Ha.
#
# Output files (in PBS_O_WORKDIR):
#   log_A.log          — Run A full OpenMolcas log
#   log_B_roots.log    — Run B per-root log (input for assemble_effe.py)
#   log_B_effe.log     — Run B EFFE + RASSI log
#   input_B_effe.input — generated by assemble_effe.py (kept for inspection)
#   comparison.txt     — PASS/FAIL energy table
#
# To run:
#   cd SO_CASSI_test/n2_effe_validation/
#   qsub run_validation.pbs

BENCH_DIR="${PBS_O_WORKDIR}"

# Load environment (reuse autoCAS4HE setup for OpenMolcas access)
INSTALL_DIR="/dodrio/scratch/projects/starting_2025_097/autoCAS4HE_built/autoCAS4HE"
source "${INSTALL_DIR}/setup_hortense.sh"

export MOLCAS_MEM=6000
export OMP_NUM_THREADS=1
export MOLCAS_PRINT=verbose

echo "========================================"
echo "  N2 EFFE Validation"
echo "========================================"
echo "Start:     $(date)"
echo "Host:      $(hostname)"
echo "PBS_JOBID: ${PBS_JOBID}"
echo ""

# ---------------------------------------------------------------------------
# Node-local working directory — all three pymolcas runs share it so that
# files saved to $CurrDir (= WORK_DIR) persist between runs.
# ---------------------------------------------------------------------------
WORK_DIR="${TMPDIR:-${BENCH_DIR}/molcas_tmp}/n2_effe_${PBS_JOBID}"
rm -rf "${WORK_DIR}"
mkdir -p "${WORK_DIR}"

# Copy static inputs and geometry into shared WORK_DIR
cp "${BENCH_DIR}/n2.xyz"              "${WORK_DIR}/"
cp "${BENCH_DIR}/input_A.input"       "${WORK_DIR}/"
cp "${BENCH_DIR}/input_B_roots.input" "${WORK_DIR}/"

# ---------------------------------------------------------------------------
# Helper: run pymolcas from WORK_DIR, log to BENCH_DIR
# ---------------------------------------------------------------------------
run_molcas() {
    local input_file="$1"
    local log_file="$2"
    export MOLCAS_WORKDIR="${WORK_DIR}"
    echo "--- pymolcas $(basename ${input_file}) at $(date) ---"
    cd "${WORK_DIR}"
    pymolcas "${input_file}" > "${log_file}" 2>&1
    local rc=$?
    if grep -qi "happy landing" "${log_file}"; then
        echo "    → Happy landing"
    else
        echo "    → WARNING: Happy landing NOT found (rc=${rc})"
    fi
    return $rc
}

# ---------------------------------------------------------------------------
# Run A — Multistate=all
# ---------------------------------------------------------------------------
echo ""
echo "=== RUN A: Multistate=all ==="
run_molcas "${WORK_DIR}/input_A.input" "${BENCH_DIR}/log_A.log"
RC_A=$?

# ---------------------------------------------------------------------------
# Run B phase 1 — 8 sequential ONLY= blocks
# ---------------------------------------------------------------------------
echo ""
echo "=== RUN B phase 1: ONLY=1..8 ==="
run_molcas "${WORK_DIR}/input_B_roots.input" "${BENCH_DIR}/log_B_roots.log"
RC_B_ROOTS=$?

# ---------------------------------------------------------------------------
# Assemble EFFE input from B_roots log
# ---------------------------------------------------------------------------
echo ""
echo "=== ASSEMBLE EFFE ==="
python3 "${BENCH_DIR}/assemble_effe.py" \
    --log       "${BENCH_DIR}/log_B_roots.log" \
    --n-roots   8 \
    --workdir   "${WORK_DIR}" \
    --frozen    2 \
    --imaginary-shift 0.25
RC_ASSEMBLE=$?

if [ ${RC_ASSEMBLE} -ne 0 ]; then
    echo "ERROR: assemble_effe.py failed (rc=${RC_ASSEMBLE})"
    exit 1
fi
# Keep a copy in BENCH_DIR for inspection
cp "${WORK_DIR}/input_B_effe.input" "${BENCH_DIR}/input_B_effe.input"

# ---------------------------------------------------------------------------
# Run B phase 2 — EFFE CASPT2 + RASSI
# ---------------------------------------------------------------------------
echo ""
echo "=== RUN B phase 2: EFFE + RASSI ==="
run_molcas "${WORK_DIR}/input_B_effe.input" "${BENCH_DIR}/log_B_effe.log"
RC_B_EFFE=$?

# ---------------------------------------------------------------------------
# Compare energies
# ---------------------------------------------------------------------------
echo ""
echo "=== COMPARE ENERGIES ==="
python3 "${BENCH_DIR}/compare_energies.py" \
    --log-a     "${BENCH_DIR}/log_A.log" \
    --log-b     "${BENCH_DIR}/log_B_effe.log" \
    --n-roots   8 \
    --threshold 1e-7 \
    | tee "${BENCH_DIR}/comparison.txt"
RC_COMPARE=$?

# Clean up node-local workdir
rm -rf "${WORK_DIR}"

echo ""
echo "========================================"
echo "  N2 EFFE Validation — Done: $(date)"
echo "  Run A exit:      ${RC_A}"
echo "  Run B_roots exit: ${RC_B_ROOTS}"
echo "  Run B_effe exit:  ${RC_B_EFFE}"
echo "  Comparison exit:  ${RC_COMPARE}  (0=PASS, 1=FAIL, 2=PARSE_ERROR)"
echo "========================================"

exit ${RC_COMPARE}
